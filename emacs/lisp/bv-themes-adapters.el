(defun bv-themes-adapters--indexed (prefix roles &optional start)
  "Return face adapter specs for PREFIX numbered by ROLES.
When START is non-nil, begin numbering from that value."
  (cl-loop for role in roles
           for index from (or start 0)
           collect (list (intern (format "%s-%d" prefix index)) role)))

(defun bv-themes-adapters--terminal-range (prefix start end)
  "Return terminal color adapter specs for PREFIX from START to END."
  (cl-loop for index from start to end
           collect (list (intern (format "%s-%d" prefix index))
                         'terminal-black
                         :fg (list 'xterm-256 index))))

