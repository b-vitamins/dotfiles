(defun bv-themes-adapters--rule-match-p (face rule)
  "Return non-nil if FACE matches package RULE."
  (let ((name (symbol-name face))
        (faces (plist-get rule :faces))
        (prefixes (plist-get rule :prefixes)))
    (or (memq face faces)
        (cl-some (lambda (prefix)
                   (string-prefix-p prefix name))
                 prefixes))))

(defun bv-themes-adapters-package-for-face (face)
  "Return the package owner for FACE."
  (catch 'package
    (dolist (entry bv-themes-adapter-package-rules)
      (when (bv-themes-adapters--rule-match-p face (cdr entry))
        (throw 'package (car entry))))
    nil))

(defun bv-themes-adapters-record (entry)
  "Return a metadata record for adapter ENTRY."
  (let* ((face (car entry))
         (role (cadr entry))
         (overrides (cddr entry)))
    (list :face face
          :role role
          :package (bv-themes-adapters-package-for-face face)
          :purpose role
          :overrides overrides
          :critical (memq role
                          '(critical critical-block error error-subtle
                            warning warning-subtle success success-subtle
                            info info-subtle diagnostic-error
                            diagnostic-warning diagnostic-info
                            diagnostic-note diff-added diff-removed
                            diff-changed terminal-default terminal-black
                            terminal-red terminal-green terminal-yellow
                            terminal-blue terminal-magenta terminal-cyan
                            terminal-white terminal-bright-black
                            terminal-bright-red terminal-bright-green
                            terminal-bright-yellow terminal-bright-blue
                            terminal-bright-magenta terminal-bright-cyan
                            terminal-bright-white)))))

(defun bv-themes-adapters-records ()
  "Return all face adapter metadata records."
  (mapcar #'bv-themes-adapters-record bv-themes-adapter-specs))

(defun bv-themes-adapters-package-counts ()
  "Return adapter counts grouped by package."
  (let (counts)
    (dolist (record (bv-themes-adapters-records))
      (let ((package (or (plist-get record :package) 'unowned)))
        (setf (alist-get package counts)
              (1+ (or (alist-get package counts) 0)))))
    (sort counts (lambda (left right)
                   (string< (symbol-name (car left))
                            (symbol-name (car right)))))))

